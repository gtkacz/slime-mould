ZIPMOULD_REPO_DIR=/opt/zipmould/slime-mould
ZIPMOULD_BRANCH=main
ZIPMOULD_ENV=production
# Defaults to $ZIPMOULD_REPO_DIR/.zipmould-run-cache. Set this to a large local disk path if preferred.
# ZIPMOULD_RUN_CACHE_DIR=/var/cache/zipmould-viz/runs
ZIPMOULD_ALLOWED_ORIGINS=https://app.zipmould.tkacz.dev.br
UV_LINK_MODE=copy
